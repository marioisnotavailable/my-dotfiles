[global]
    font = JetBrainsMono Nerd Font 11
    markup = full
    format = "<b>%s</b>\n%b"
    sort = yes
    indicate_hidden = yes
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    
    # Ironbar Pill Style
    width = 320
    height = (0, 300)
    origin = top-center
    offset = (0, 60)
    transparency = 15
    idle_threshold = 120
    monitor = 0
    follow = none
    sticky_history = yes
    history_length = 20
    show_indicators = yes
    line_height = 0
    separator_height = 2
    padding = 16
    horizontal_padding = 20
    separator_color = frame
    
    # Matching Ironbar Pill
    frame_width = 0
    corner_radius = 20
    gap_size = 8

    icon_position = left
    max_icon_size = 48
    
[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 15

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 15

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    timeout = 0
